{
  "openapi": "3.1.0",
  "info": {
    "title": "Agent-First Transcription API",
    "description": "Asynchronous transcription service for video/audio inputs.",
    "version": "0.1.0"
  },
  "paths": {
    "/api-keys": {
      "post": {
        "tags": [
          "Transcriptions",
          "System"
        ],
        "summary": "Create API key",
        "description": "Create a new API key for agent bootstrap. Returns the secret key once; store it securely.",
        "operationId": "create_api_key_api_keys_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApiKeyCreateRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiKeyCreateResponse"
                }
              }
            }
          },
          "500": {
            "description": "Failed to create API key.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/transcriptions": {
      "post": {
        "tags": [
          "Transcriptions"
        ],
        "summary": "Submit transcription job",
        "description": "Create a new asynchronous transcription job from a local file upload or a public media URL.",
        "operationId": "create_transcription_transcriptions_post",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_create_transcription_transcriptions_post"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Job accepted for processing.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CreateTranscriptionResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request payload.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "413": {
            "description": "Uploaded file is too large.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "get": {
        "tags": [
          "Transcriptions"
        ],
        "summary": "List recent transcription jobs",
        "description": "Return a paginated list of recent transcription jobs and their current status.",
        "operationId": "list_transcriptions_transcriptions_get",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 20,
              "title": "Limit"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "A list of transcription jobs.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TranscriptionJobStatus"
                  },
                  "title": "Response List Transcriptions Transcriptions Get"
                }
              }
            }
          },
          "400": {
            "description": "Invalid query parameters.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/transcriptions/{job_id}": {
      "get": {
        "tags": [
          "Transcriptions"
        ],
        "summary": "Get transcription job status",
        "description": "Return the current processing state of a transcription job.",
        "operationId": "get_transcription_status_transcriptions__job_id__get",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Job status returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranscriptionJobStatus"
                }
              }
            }
          },
          "404": {
            "description": "Job not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/transcriptions/{job_id}/result": {
      "get": {
        "tags": [
          "Transcriptions"
        ],
        "summary": "Fetch transcription result",
        "description": "Return the structured transcription output for a completed job, including diarized transcript segments.",
        "operationId": "get_transcription_result_transcriptions__job_id__result_get",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transcription result returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranscriptionResultEnvelope"
                }
              }
            }
          },
          "202": {
            "description": "Job is still processing."
          },
          "404": {
            "description": "Job not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/transcriptions/{job_id}/result/raw": {
      "get": {
        "tags": [
          "Transcriptions"
        ],
        "summary": "Fetch raw transcription result",
        "description": "Return the exact structured transcription output without the status envelope.",
        "operationId": "get_raw_transcription_result_transcriptions__job_id__result_raw_get",
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "parameters": [
          {
            "name": "job_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Job Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Transcription result returned.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TranscriptionResult"
                }
              }
            }
          },
          "202": {
            "description": "Job is still processing."
          },
          "404": {
            "description": "Job not found.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "409": {
            "description": "Job failed.",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/schemas/transcription-result": {
      "get": {
        "tags": [
          "Transcriptions",
          "System"
        ],
        "summary": "Get TranscriptionResult JSON Schema",
        "description": "Return the JSON schema for the TranscriptionResult object, useful for programmatic clients.",
        "operationId": "get_transcription_result_schema_schemas_transcription_result_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "type": "object",
                  "title": "Response Get Transcription Result Schema Schemas Transcription Result Get"
                }
              }
            }
          }
        }
      }
    },
    "/usage": {
      "get": {
        "tags": [
          "Transcriptions",
          "System"
        ],
        "summary": "Get API Key Usage",
        "description": "Fetch your current API key usage, remaining quota, and available rate limit tokens.",
        "operationId": "get_api_usage_usage_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UsageResponse"
                }
              }
            }
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ]
      }
    },
    "/health": {
      "get": {
        "tags": [
          "Transcriptions",
          "System"
        ],
        "summary": "Health Check",
        "description": "Free health check \u2014 no token deduction.",
        "operationId": "health_check_health_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {
                    "type": "string"
                  },
                  "type": "object",
                  "title": "Response Health Check Health Get"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ApiKeyCreateRequest": {
        "properties": {
          "label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Label",
            "description": "Optional label for the API key (e.g., agent name or workflow id).",
            "example": "autonomous-agent-1"
          },
          "quota": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Quota",
            "description": "Optional quota override. If omitted, a generous default quota is applied.",
            "example": 25
          }
        },
        "type": "object",
        "title": "ApiKeyCreateRequest"
      },
      "ApiKeyCreateResponse": {
        "properties": {
          "id": {
            "type": "string",
            "title": "Id",
            "description": "Unique API key identifier"
          },
          "api_key": {
            "type": "string",
            "title": "Api Key",
            "description": "Secret API key value. Returned only once."
          },
          "label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Label",
            "description": "Label associated with the key"
          },
          "quota": {
            "type": "integer",
            "title": "Quota",
            "description": "Quota assigned to this key"
          }
        },
        "type": "object",
        "required": [
          "id",
          "api_key",
          "quota"
        ],
        "title": "ApiKeyCreateResponse"
      },
      "Body_create_transcription_transcriptions_post": {
        "properties": {
          "file": {
            "anyOf": [
              {
                "type": "string",
                "format": "binary"
              },
              {
                "type": "null"
              }
            ],
            "title": "File",
            "description": "A video or audio file upload. Required if source_url is not provided."
          },
          "source_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Source Url",
            "description": "Public URL to a video/audio file. Required if file is not provided."
          },
          "model": {
            "type": "string",
            "title": "Model",
            "description": "Gemini model to use for transcription. If omitted, uses gemini-2.5-flash.",
            "default": "gemini-2.5-flash"
          },
          "callback_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Callback Url",
            "description": "Optional webhook URL to receive job completion notifications."
          }
        },
        "type": "object",
        "title": "Body_create_transcription_transcriptions_post"
      },
      "CreateTranscriptionResponse": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id",
            "description": "Unique transcription job identifier",
            "example": "324fbb04-6a02-4a23-9f89-6ad2460d7ecb"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Initial job status",
            "example": "PENDING"
          },
          "location": {
            "type": "string",
            "title": "Location",
            "description": "URL to fetch job status",
            "example": "/transcriptions/324fbb04-6a02-4a23-9f89-6ad2460d7ecb"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "status",
          "location"
        ],
        "title": "CreateTranscriptionResponse",
        "example": {
          "job_id": "324fbb04-6a02-4a23-9f89-6ad2460d7ecb",
          "location": "/transcriptions/324fbb04-6a02-4a23-9f89-6ad2460d7ecb",
          "status": "PENDING"
        }
      },
      "DiarizedSegment": {
        "properties": {
          "speaker": {
            "type": "string",
            "title": "Speaker"
          },
          "text": {
            "type": "string",
            "title": "Text"
          },
          "originalText": {
            "type": "string",
            "title": "Originaltext"
          },
          "language": {
            "type": "string",
            "title": "Language"
          },
          "languageName": {
            "type": "string",
            "title": "Languagename"
          }
        },
        "type": "object",
        "required": [
          "speaker",
          "text",
          "originalText",
          "language",
          "languageName"
        ],
        "title": "DiarizedSegment"
      },
      "ErrorResponse": {
        "properties": {
          "code": {
            "type": "string",
            "title": "Code",
            "description": "Machine-readable error code",
            "example": "INVALID_INPUT"
          },
          "message": {
            "type": "string",
            "title": "Message",
            "description": "Detailed human-readable error message",
            "example": "Please provide either a file upload or a source_url."
          },
          "suggested_action": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Suggested Action",
            "description": "Suggested next action for the caller",
            "example": "Send only one of file or source_url."
          },
          "details": {
            "anyOf": [
              {
                "additionalProperties": true,
                "type": "object"
              },
              {
                "type": "null"
              }
            ],
            "title": "Details",
            "description": "Optional structured error details"
          }
        },
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "title": "ErrorResponse"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "TranscriptionJobStatus": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id",
            "description": "Unique transcription job identifier",
            "example": "324fbb04-6a02-4a23-9f89-6ad2460d7ecb"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Current job status",
            "example": "RUNNING"
          },
          "stage": {
            "type": "string",
            "title": "Stage",
            "description": "Current pipeline stage",
            "example": "TRANSCRIBING"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "title": "Created At",
            "description": "Timestamp when the job was created"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "title": "Updated At",
            "description": "Timestamp when the job was last updated"
          },
          "result_url": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Result Url",
            "description": "URL to fetch the transcription result when complete",
            "example": "/transcriptions/324fbb04-6a02-4a23-9f89-6ad2460d7ecb/result"
          },
          "error_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Code",
            "description": "Machine-readable error code if job failed",
            "example": "TRANSCRIPTION_ERROR"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message",
            "description": "Human-readable error message if job failed"
          },
          "suggested_action": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Suggested Action",
            "description": "Suggested next action for the caller"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "status",
          "stage",
          "created_at",
          "updated_at"
        ],
        "title": "TranscriptionJobStatus",
        "example": {
          "created_at": "2026-05-27T10:15:13.112737Z",
          "job_id": "324fbb04-6a02-4a23-9f89-6ad2460d7ecb",
          "stage": "TRANSCRIBING",
          "status": "RUNNING",
          "updated_at": "2026-05-27T10:15:26.222793Z"
        }
      },
      "TranscriptionResult": {
        "properties": {
          "text": {
            "type": "string",
            "title": "Text"
          },
          "diarizedTranscript": {
            "items": {
              "$ref": "#/components/schemas/DiarizedSegment"
            },
            "type": "array",
            "title": "Diarizedtranscript"
          },
          "audioMode": {
            "type": "string",
            "enum": [
              "spoken-narration",
              "music-only",
              "music-with-lyrics",
              "silent",
              "mixed"
            ],
            "title": "Audiomode"
          },
          "detectedLanguage": {
            "type": "string",
            "title": "Detectedlanguage"
          },
          "detectedLanguageName": {
            "type": "string",
            "title": "Detectedlanguagename"
          },
          "languagesUsed": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Languagesused"
          },
          "languagesUsedNames": {
            "items": {
              "type": "string"
            },
            "type": "array",
            "title": "Languagesusednames"
          },
          "isTranslated": {
            "type": "boolean",
            "title": "Istranslated"
          }
        },
        "type": "object",
        "required": [
          "text",
          "diarizedTranscript",
          "audioMode",
          "detectedLanguage",
          "detectedLanguageName",
          "languagesUsed",
          "languagesUsedNames",
          "isTranslated"
        ],
        "title": "TranscriptionResult"
      },
      "TranscriptionResultEnvelope": {
        "properties": {
          "job_id": {
            "type": "string",
            "title": "Job Id",
            "description": "Unique transcription job identifier",
            "example": "324fbb04-6a02-4a23-9f89-6ad2460d7ecb"
          },
          "status": {
            "type": "string",
            "title": "Status",
            "description": "Current job status",
            "example": "COMPLETED"
          },
          "stage": {
            "type": "string",
            "title": "Stage",
            "description": "Current pipeline stage",
            "example": "FINALIZING"
          },
          "result": {
            "anyOf": [
              {
                "$ref": "#/components/schemas/TranscriptionResult"
              },
              {
                "type": "null"
              }
            ],
            "description": "Structured transcription output according to the TranscriptionResult schema"
          },
          "error_code": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Code",
            "description": "Machine-readable error code if job failed"
          },
          "error_message": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Error Message",
            "description": "Human-readable error message if job failed"
          },
          "suggested_action": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Suggested Action",
            "description": "Suggested next action for the caller"
          }
        },
        "type": "object",
        "required": [
          "job_id",
          "status",
          "stage"
        ],
        "title": "TranscriptionResultEnvelope",
        "example": {
          "job_id": "324fbb04-6a02-4a23-9f89-6ad2460d7ecb",
          "result": {
            "audioMode": "spoken-narration",
            "detectedLanguage": "en",
            "detectedLanguageName": "English",
            "diarizedTranscript": [
              {
                "language": "en",
                "languageName": "English",
                "originalText": "Hello world",
                "speaker": "creator",
                "text": "Hello world"
              }
            ],
            "isTranslated": false,
            "languagesUsed": [
              "en"
            ],
            "languagesUsedNames": [
              "English"
            ],
            "text": "Hello world"
          },
          "stage": "FINALIZING",
          "status": "COMPLETED"
        }
      },
      "UsageResponse": {
        "properties": {
          "api_key_id": {
            "type": "string",
            "title": "Api Key Id",
            "description": "The unique ID of the API key"
          },
          "label": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Label",
            "description": "The label given to the key"
          },
          "usage_count": {
            "type": "integer",
            "title": "Usage Count",
            "description": "Total number of jobs submitted"
          },
          "quota": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
